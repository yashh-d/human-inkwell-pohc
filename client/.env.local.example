# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.
# All client env vars must be prefixed with REACT_APP_ to be visible in the browser.
# After ANY change, restart `npm start` (local) or trigger a new Vercel build (production).

# —— World ID 4.0 (IDKit 4) ——
# From https://developer.world.org/ after “Enable World ID 4.0 / RP”:
REACT_APP_WORLD_APP_ID=app_xxxxxxxx
REACT_APP_WORLD_RP_ID=rp_xxxxxxxx
# Same action string you created in the portal for this app:
REACT_APP_WORLD_ACTION=verify_human_content
# Signal bound into the MNC (device) proof — any stable string per your security model:
REACT_APP_WORLD_SIGNAL=human-inkwell
# "staging" to use the simulator, else production
REACT_APP_WORLD_ENABLE_STAGING=false
# Optional: if the browser calls APIs on a different origin (rare)
# REACT_APP_PUBLIC_BASE_URL=https://your-app.vercel.app

# Server-only (Vercel env — NOT in .env.local for a static deploy in browser, add in Vercel only):
# RP_SIGNING_KEY=<hex from Developer Portal — used by /api/rp-signature only>

# World Chain Sepolia — set to your deployed HumanContentLedger
REACT_APP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_CHAIN_ID=4801
REACT_APP_NETWORK_NAME=World Chain Sepolia
REACT_APP_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
REACT_APP_BLOCKCHAIN_EXPLORER_URL=https://sepolia.worldscan.org
