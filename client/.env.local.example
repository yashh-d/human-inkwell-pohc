# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.
# All client env vars must be prefixed with REACT_APP_ to be visible in the browser.
# After ANY change, restart `npm start` (local) or trigger a new Vercel build (production).

# World ID — set REACT_APP_WORLD_APP_ID on Vercel or World ID + World App will fail in production.
# In developer.world.org, add your real site origin (e.g. https://your-app.vercel.app) to the app.
REACT_APP_WORLD_APP_ID=app_staging_xxx
REACT_APP_WORLD_ACTION=verify_human_content
REACT_APP_WORLD_VERIFICATION_LEVEL=device
REACT_APP_WORLD_ENABLE_STAGING=false

# World Chain Sepolia — set to your deployed HumanContentLedger
REACT_APP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_CHAIN_ID=4801
REACT_APP_NETWORK_NAME=World Chain Sepolia
REACT_APP_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
# Same RPC + contract are read by Vercel serverless `api/ledger-onchain.js` (on-chain verify before Supabase insert).
# Block explorer: use Alchemy Blockscout (default). Worldscan env URLs are auto-mapped to this in the app.
REACT_APP_BLOCKCHAIN_EXPLORER_URL=https://worldchain-sepolia.explorer.alchemy.com

# Ledger API (Vercel serverless: client/api/ledger-onchain.js, ledger.js, my-ledger.js)
# Use plain names (no REACT_APP_) for Supabase in Vercel — server-only, never embedded in the JS bundle.
#   SUPABASE_URL=https://xxxx.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=...  (service role; if you used REACT_APP_ it would risk exposing it in the client build)
# SQL: run supabase/migrations/20260426120000_create_ledger_submissions.sql
# Local full stack: run `vercel dev` in client/  (or set REACT_APP_API_BASE to a preview URL)
# REACT_APP_API_BASE=https://your-app.vercel.app
